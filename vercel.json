{
  "builds": [
    {
      "src": "dabbleX-freight..py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dabbleX-freight..py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}