{
  "builds": [
    {
      "src": "DrishX/drishx.py",
      "use": "@vercel/python"
    },
    {
      "src": "DrishX/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "DrishX/drishx.py"
    },
    {
      "src": "/(.*)",
      "dest": "DrishX/frontend/$1"
    }
  ]
}
