# DrishX: Satellite Intelligence Environment
# Copy this file to .env and fill in your tactical credentials.

# Copernicus Data Space Ecosystem (CDSE)
COPERNICUS_CLIENT_ID=00000000-0000-0000-0000-000000000000
COPERNICUS_CLIENT_SECRET=your_secret_here

# Operational Storage
# Optional: Defaults to ./drishx_data
DRISHX_DATA_DIR=./drishx_data

# Model Tracking
RF_MODEL_PATH=rf_model.pickle
