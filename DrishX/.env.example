# ARGUS v2.0 Environment Configuration
# Copy to .env and fill in your credentials

# Copernicus Data Space (Sentinel-2 satellite imagery)
COPERNICUS_CLIENT_ID=your-client-id-here
COPERNICUS_CLIENT_SECRET=your-client-secret-here

# PostgreSQL Database
DATABASE_URL=postgresql://argus:argus@postgres:5432/argus

# Redis Cache / PubSub
REDIS_URL=redis://redis:6379/0

# Ollama LLM Service
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Data Directory
DRISHX_DATA_DIR=/app/drishx_data

# Open Data API Keys (optional - falls back to free tiers / open feeds)
OPENWEATHER_API_KEY=
TOMTOM_API_KEY=
HERE_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Application Settings
LOG_LEVEL=INFO
MAX_FRAMES_DEFAULT=10
MAX_AOI_SIZE_KM=55

# Background ingestion layer (ARGUS data feeds)
ENABLE_INGESTION=0
